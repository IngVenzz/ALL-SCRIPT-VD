end


local function reloadCrosshair()
    if not isActive then return end
    removeCrosshair()
    createCrosshair()
end


local function setupCutsceneDetection()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    playerGui.DescendantAdded:Connect(function(descendant)
        local nameLower = descendant.Name:lower()
        
        if nameLower:find("cutscene") or 
           nameLower:find("cinematic") or 
           nameLower:find("transition") or
           nameLower:find("loading") or
           nameLower:find("black") or
           nameLower:find("fade") then
            
            if screenGui then
                screenGui.Enabled = false
            end
            
            local waitTime = 0
            while waitTime < 5 do
                local stillExists = descendant.Parent ~= nil
                if not stillExists then break end
                wait(0.5)
                waitTime = waitTime + 0.5
            end
            
            if isActive then
                wait(0.3)
                if screenGui then
                    screenGui.Enabled = true
                end
                reloadCrosshair()
            end
        end
    end)
    
    playerGui.DescendantRemoved:Connect(function(descendant)
        if descendant == screenGui then
            if isActive then
                wait(0.1)
                reloadCrosshair()
            end
        end
    end)
end


local function setupRespawnDetection()
    player.CharacterAdded:Connect(function()
        if isActive then
            wait(0.5)
            reloadCrosshair()
        end
    end)
end


reloadCrosshair()
setupCutsceneDetection()
setupRespawnDetection()
