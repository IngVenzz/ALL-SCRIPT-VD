local replicatedStorage = game:GetService("ReplicatedStorage")
local playersService = game:GetService("Players")
local player = playersService.LocalPlayer


local function getStalkingRemotes()
    local remotes = replicatedStorage:FindFirstChild("Remotes")
    if not remotes then return nil end
    
    local killers = remotes:FindFirstChild("Killers")
    if not killers then return nil end
    
    return {
        startStalking = killers:FindFirstChild("StartStalking"),
        stopStalking = killers:FindFirstChild("StopStalking"),
        updateStalking = killers:FindFirstChild("UpdateStalking"),
        evolveStage = killers:FindFirstChild("EvolveStage")
    }
end


local function removeStalkingCooldown()
    local playerData = player:FindFirstChild("Data")
    if playerData then
        local cooldowns = playerData:FindFirstChild("Cooldowns")
        if cooldowns then
            for _, cd in ipairs(cooldowns:GetChildren()) do
                if cd:IsA("NumberValue") then
                    local name = cd.Name:lower()
                    if name:find("stalk") or name:find("stalking") or name:find("evolve") then
                        cd.Value = 0
                    end
                end
            end
        end
        
        local killerData = playerData:FindFirstChild("KillerData")
        if killerData then
            local stalkCD = killerData:FindFirstChild("StalkCooldown")
            if stalkCD then stalkCD.Value = 0 end
            local evolveCD = killerData:FindFirstChild("EvolveCooldown")
            if evolveCD then evolveCD.Value = 0 end
            local stalkProgress = killerData:FindFirstChild("StalkProgress")
            if stalkProgress then stalkProgress.Value = 100 end
        end
    end
end


local function updateStalking(value)
    local remotes = getStalkingRemotes()
    if remotes and remotes.updateStalking and remotes.updateStalking:IsA("RemoteEvent") then
        pcall(function()
            remotes.updateStalking:FireServer(value or 100)
        end)
    end
end


local function evolveToTier3()
    local remotes = getStalkingRemotes()
    if remotes and remotes.evolveStage and remotes.evolveStage:IsA("RemoteEvent") then
        pcall(function()
            remotes.evolveStage:FireServer(3)
        end)
    end
end


local function startStalking()
    local remotes = getStalkingRemotes()
    if remotes and remotes.startStalking and remotes.startStalking:IsA("RemoteEvent") then
        pcall(function()
            remotes.startStalking:FireServer()
        end)
    end
end


local function stopStalking()
    local remotes = getStalkingRemotes()
    if remotes and remotes.stopStalking and remotes.stopStalking:IsA("RemoteEvent") then
        pcall(function()
            remotes.stopStalking:FireServer()
        end)
    end
end


removeStalkingCooldown()
updateStalking(100)

-- Perintah
_G.startStalk = startStalking
_G.stopStalk = stopStalking
_G.resetStalkCD = removeStalkingCooldown
_G.setStalkProgress = updateStalking
_G.evolveTier3 = evolveToTier3
